{
  "info": {
    "_postman_id": "task-api-collection-v1",
    "name": "Task Management API",
    "description": "Complete Postman collection for the Task Management API System built with Laravel 12 + Sanctum.\n\n**Setup:**\n1. Import this collection\n2. Set the `base_url` variable to `http://127.0.0.1:8000/api`\n3. Register or login to get a token\n4. The token is auto-saved to the `token` collection variable after login/register",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "    pm.collectionVariables.set('token', json.data.token);",
                  "    console.log('Token saved:', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Shadab Alam\",\n  \"email\": \"shadab@example.com\",\n  \"password\": \"secret123\",\n  \"password_confirmation\": \"secret123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/register", "host": ["{{base_url}}"], "path": ["register"] }
          },
          "response": [
            {
              "name": "Success (201)",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"message\": \"User registered successfully.\",\n  \"data\": {\n    \"user\": {\n      \"id\": 1,\n      \"name\": \"Shadab Alam\",\n      \"email\": \"shadab@example.com\",\n      \"created_at\": \"2026-03-31T15:00:00.000000Z\",\n      \"updated_at\": \"2026-03-31T15:00:00.000000Z\"\n    },\n    \"token\": \"1|abc123xyz...\"\n  }\n}"
            },
            {
              "name": "Validation Error (422)",
              "status": "Unprocessable Content",
              "code": 422,
              "body": "{\n  \"success\": false,\n  \"message\": \"Validation failed.\",\n  \"errors\": {\n    \"email\": [\"The email has already been taken.\"]\n  }\n}"
            }
          ]
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "    pm.collectionVariables.set('token', json.data.token);",
                  "    console.log('Token saved:', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"shadab@example.com\",\n  \"password\": \"secret123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
          },
          "response": [
            {
              "name": "Success (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Logged in successfully.\",\n  \"data\": {\n    \"user\": { \"id\": 1, \"name\": \"Shadab Alam\", \"email\": \"shadab@example.com\" },\n    \"token\": \"2|xyz789abc...\"\n  }\n}"
            },
            {
              "name": "Invalid Credentials (401)",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"success\": false,\n  \"message\": \"Invalid credentials. Please check your email and password.\"\n}"
            }
          ]
        },
        {
          "name": "Get Profile (me)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/me", "host": ["{{base_url}}"], "path": ["me"] }
          },
          "response": [
            {
              "name": "Success (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"id\": 1,\n    \"name\": \"Shadab Alam\",\n    \"email\": \"shadab@example.com\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/logout", "host": ["{{base_url}}"], "path": ["logout"] }
          },
          "response": [
            {
              "name": "Success (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Logged out successfully.\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "List Tasks",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/tasks",
              "host": ["{{base_url}}"],
              "path": ["tasks"],
              "query": [
                { "key": "status", "value": "pending", "disabled": true, "description": "Filter: pending | in-progress | completed" },
                { "key": "due_date", "value": "2026-04-15", "disabled": true, "description": "Filter by exact due date (YYYY-MM-DD)" },
                { "key": "page", "value": "1", "disabled": true, "description": "Page number (10 per page)" }
              ]
            }
          },
          "response": [
            {
              "name": "Success (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"current_page\": 1,\n    \"data\": [\n      {\n        \"id\": 1,\n        \"user_id\": 1,\n        \"title\": \"Build task API\",\n        \"description\": \"Complete with tests.\",\n        \"status\": \"in-progress\",\n        \"due_date\": \"2026-04-15\",\n        \"created_at\": \"2026-03-31T15:00:00.000000Z\",\n        \"updated_at\": \"2026-03-31T15:00:00.000000Z\"\n      }\n    ],\n    \"last_page\": 1,\n    \"per_page\": 10,\n    \"total\": 1\n  }\n}"
            }
          ]
        },
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Build task API\",\n  \"description\": \"Complete with tests and documentation.\",\n  \"status\": \"in-progress\",\n  \"due_date\": \"2026-04-15\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/tasks", "host": ["{{base_url}}"], "path": ["tasks"] }
          },
          "response": [
            {
              "name": "Created (201)",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"message\": \"Task created successfully.\",\n  \"data\": {\n    \"id\": 1,\n    \"user_id\": 1,\n    \"title\": \"Build task API\",\n    \"description\": \"Complete with tests and documentation.\",\n    \"status\": \"in-progress\",\n    \"due_date\": \"2026-04-15\",\n    \"created_at\": \"2026-03-31T15:00:00.000000Z\",\n    \"updated_at\": \"2026-03-31T15:00:00.000000Z\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Get Single Task",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/tasks/1", "host": ["{{base_url}}"], "path": ["tasks", "1"] }
          },
          "response": [
            {
              "name": "Success (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"id\": 1,\n    \"user_id\": 1,\n    \"title\": \"Build task API\",\n    \"status\": \"in-progress\",\n    \"due_date\": \"2026-04-15\"\n  }\n}"
            },
            {
              "name": "Forbidden (403)",
              "status": "Forbidden",
              "code": 403,
              "body": "{\n  \"success\": false,\n  \"message\": \"You are not authorized to access this task.\"\n}"
            }
          ]
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"completed\",\n  \"title\": \"Build task API (done)\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/tasks/1", "host": ["{{base_url}}"], "path": ["tasks", "1"] }
          },
          "response": [
            {
              "name": "Success (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Task updated successfully.\",\n  \"data\": {\n    \"id\": 1,\n    \"title\": \"Build task API (done)\",\n    \"status\": \"completed\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Delete Task (Soft)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/tasks/1", "host": ["{{base_url}}"], "path": ["tasks", "1"] }
          },
          "response": [
            {
              "name": "Success (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Task deleted successfully.\"\n}"
            }
          ]
        }
      ]
    }
  ]
}
